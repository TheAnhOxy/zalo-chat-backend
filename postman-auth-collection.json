{
  "info": {
    "_postman_id": "zalo-chat-auth-2026",
    "name": "Zalo Chat Auth API",
    "description": "Auth flow collection for register -> verify -> login -> refresh token using real OTP from inbox.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Main Auth Flow",
      "item": [
        {
          "name": "1. Register - send OTP to email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('sessionId', jsonData.data.sessionId);",
                  "pm.environment.set('email', jsonData.data.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"{{phone}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "2. Verify Register OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('userId', jsonData.data.user.id);",
                  "pm.environment.set('accessToken', jsonData.data.tokens.accessToken);",
                  "pm.environment.set('refreshToken', jsonData.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-register-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-register-otp"]
            }
          },
          "response": []
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('userId', jsonData.data.user.id);",
                  "pm.environment.set('accessToken', jsonData.data.tokens.accessToken);",
                  "pm.environment.set('refreshToken', jsonData.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"device\": \"web\",\n  \"deviceName\": \"Postman Windows\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('accessToken', jsonData.data.accessToken);",
                  "pm.environment.set('refreshToken', jsonData.data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh-token",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh-token"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Password & Session",
      "item": [
        {
          "name": "5. Logout Current Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "6. Forgot Password - Request OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('sessionId', jsonData.data.sessionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/forgot-password/request-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "forgot-password", "request-otp"]
            }
          },
          "response": []
        },
        {
          "name": "7. Forgot Password - Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/forgot-password/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "forgot-password", "verify-otp"]
            }
          },
          "response": []
        },
        {
          "name": "8. Resend OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('sessionId', jsonData.data.sessionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/otp/resend",
              "host": ["{{base_url}}"],
              "path": ["auth", "otp", "resend"]
            }
          },
          "response": []
        },
        {
          "name": "9. Get Sessions by User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/sessions/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "sessions", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "10. Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"oldPassword\": \"{{password}}\",\n  \"newPassword\": \"{{finalPassword}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "change-password"]
            }
          },
          "response": []
        },
        {
          "name": "11. Logout All Devices",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout-all-devices",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout-all-devices"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Phone OTP Login",
      "item": [
        {
          "name": "12. Phone Login - Request OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('sessionId', jsonData.data.sessionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/phone-login/request-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "phone-login", "request-otp"]
            }
          },
          "response": []
        },
        {
          "name": "13. Phone Login - Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('userId', jsonData.data.user.id);",
                  "pm.environment.set('accessToken', jsonData.data.tokens.accessToken);",
                  "pm.environment.set('refreshToken', jsonData.data.tokens.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/phone-login/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "phone-login", "verify-otp"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Tests",
      "item": [
