            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"phone\": \"1234567890\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
