              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"otp\": \"000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-register-otp",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-register-otp"]
            }
          },
          "response": []
        },
        {
          "name": "[ERROR TEST] Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
